{
	"extends": "@tsconfig/svelte/tsconfig.json",
	"compilerOptions": {
		"target": "ESNext",
		"useDefineForClassFields": true,
		"module": "ESNext",
		"resolveJsonModule": true,
		"baseUrl": ".",
		"strict": true,
		"noEmit": true
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"node_modules/*"
	]
}